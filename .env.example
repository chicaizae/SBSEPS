# SBSEPS v1.0 - Configuracion base Linux

NODE_ENV=production
PORT=8080

# MariaDB. Si DB_HOST se omite, la app usa SQLite local SBSEPS.db.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=SBSEPS
DB_USER=seguridadinf
DB_PASSWORD=seguridadinf

# Cambiar obligatoriamente en produccion.
SESSION_SECRET=cambie-este-secreto-largo-y-aleatorio

# Limites de carga
MAX_UPLOAD_MB=25
MAX_UPDATE_MB=100

# Opcional si se usa SQLite
# SQLITE_PATH=/opt/sbseps/data/SBSEPS.db
